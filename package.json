{
  "name": "elements-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "prestart": "node scripts/print-review-urls.js",
    "start": "vite --port 8875 --host 127.0.0.1",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "npm run build:runtime-assets",
    "build:runtime-assets": "node scripts/copy-runtime-assets.mjs",
    "build:agentation": "vite build --config vite.agentation.config.mjs",
    "build:vercel": "npm run build && npm run build:agentation && npm run build:runtime-assets",
    "preview": "vite preview",
    "lint": "eslint src vite.config.ts eslint.config.js",
    "format": "prettier --check ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "agentation": "^3.0.2",
    "eslint": "^9.39.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14"
  }
}
