# Vercel → Settings → Environment Variables
# Ustaw osobno dla Production (klient) i Preview (zespół) — patrz docs/DEPLOY.md

# --- Server (Production + Preview) ---
GITHUB_TOKEN=ghp_xxxxxxxx
GITHUB_REPO=bronisMateusz/Demo-Elements
# Dozwolone originy dla POST /api/agentation-feedback (środowisko zespołu)
ALLOWED_ORIGINS=https://demo-elements-team.vercel.app,http://localhost:5173,http://localhost:8875

# --- Frontend: środowisko ZESPOŁU (Preview / branch main) ---
# VITE_DEPLOY_TARGET=team
# VITE_AGENTATION_ENABLED=true
# VITE_AGENTATION_WEBHOOK_URL=/api/agentation-feedback

# --- Frontend: środowisko KLIENTA (Production / branch release) ---
# VITE_DEPLOY_TARGET=client
# VITE_AGENTATION_ENABLED=false

# Lokalny dev z review (opcjonalnie .env.local):
# VITE_DEPLOY_TARGET=team
# VITE_AGENTATION_ENABLED=true
