# Lokalny dev — skopiuj do .env.local w katalogu głównym projektu:
#   cp env/local.example.env .env.local
#
# npm run dev / npm start — Agentation zawsze włączone
# npx vercel dev — frontend + API (wymaga GITHUB_TOKEN)

VITE_DEPLOY_TARGET=team
VITE_AGENTATION_ENABLED=true
VITE_AGENTATION_WEBHOOK_URL=/api/agentation-feedback
